{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "TableComparator": "Debug"
    }
  },

  "Schedule": {
    "CronExpression": "*/30 * * * *",
    "RunOnStartup": true
  },

  "Agent": {
    "ModelName": "llama3.1",
    "OllamaBaseUrl": "",
    "ContextSize": 8192,
    "SourceLabel": "Production DB",
    "TargetLabel": "Recalculation DB"
  },

  "Databases": {
    "SourceConnectionString": "",
    "TargetConnectionString": ""
  },

  "Report": {
    "WriteJsonReports": true,
    "ReportDirectory": "reports"
  },

  "Reporting": {
    "NotifyOnlyOnDiscrepancies": false,

    "Email": {
      "Enabled": false,
      "SmtpHost": "smtp.office365.com",
      "SmtpPort": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "",
      "FromName": "",
      "ToAddresses": [ "" ],
      "CcAddresses": []
    },

    "Teams": {
      "Enabled": false,
      "WebhookUrl": "https://outlook.office.com/webhook/YOUR_WEBHOOK_URL",
      "OnlyOnDiscrepancies": false
    }
  }
}
